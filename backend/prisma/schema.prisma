generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SearchBatchStatus {
  draft
  ready
  processing
  done
  done_with_errors
  error
}

enum CompanyStatus {
  pending
  loading_ares
  finding_web
  crawling
  extracting
  done
  no_results
  error
}

enum ImportLogStatus {
  imported
  skipped
  invalid
  duplicate
}

enum ProcessingLogStatus {
  info
  success
  warning
  error
}

enum CompanyWebsiteSource {
  search
  ares
  manual
  imported
  other
}

enum CrawledPageSource {
  website_root
  internal_link
  sitemap
  manual
}

enum CrawledPageStatus {
  pending
  fetched
  skipped
  error
}

enum ExtractionMethod {
  regex
  html_structure
  llm
  manual
  imported
}

enum ReviewStatus {
  unreviewed
  confirmed
  rejected
  manually_edited
}

enum ContactType {
  email
  phone
  general_email
  general_phone
  databox
  other
}

enum ContactScoreCategory {
  high
  medium
  low
  needs_review
}

model SearchBatch {
  id             String            @id @default(cuid())
  name           String
  note           String?
  targetRole     String?
  status         SearchBatchStatus @default(draft)
  currentStep    String            @default("import")
  progressPercent Int              @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  lastErrorMessage String?
  totalCount     Int               @default(0)
  processedCount Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  companies      Company[]
  importLogs     ImportLog[]
  processingLogs ProcessingLog[]
}

model Company {
  id                    String        @id @default(cuid())
  batchId               String
  ico                   String
  companyName           String?
  legalForm             String?
  addressText           String?
  city                  String?
  postalCode            String?
  country               String?
  registrationStatus    String?
  createdDate           DateTime?
  dataBoxId             String?
  aresRawJson           Json?
  aresLoadedAt          DateTime?
  statutoryPersonsJson  Json?
  websiteUrl            String?
  websiteDomain         String?
  websiteConfidenceScore Int?
  websiteFoundAt        DateTime?
  crawledAt             DateTime?
  crawledPagesCount     Int?          @default(0)
  crawlErrorMessage     String?
  extractedAt           DateTime?
  personsCount          Int?          @default(0)
  contactsCount         Int?          @default(0)
  extractionErrorMessage String?
  bestPersonId          String?
  bestContactId         String?
  bestContactScore      Int?
  finalPersonId         String?
  finalContactId        String?
  finalDecisionSource   String?
  finalNote             String?
  scoredAt              DateTime?
  status                CompanyStatus @default(pending)
  errorMessage          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  batch           SearchBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  processingLogs  ProcessingLog[]
  websites        CompanyWebsite[]
  crawledPages    CrawledPage[]
  persons         CompanyPerson[]
  contacts        CompanyContact[]
  contactScores   ContactScore[]

  @@unique([batchId, ico])
  @@index([batchId])
}

model CrawledPage {
  id                String            @id @default(cuid())
  companyId         String
  url               String
  normalizedUrl     String
  domain            String
  title             String?
  htmlContent       String?
  textContent       String?
  httpStatus        Int?
  contentType       String?
  depth             Int               @default(0)
  source            CrawledPageSource
  crawlStatus       CrawledPageStatus @default(pending)
  errorMessage      String?
  discoveredFromUrl String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  persons  CompanyPerson[]
  contacts CompanyContact[]

  @@index([companyId, createdAt])
  @@index([companyId, normalizedUrl])
}

model CompanyWebsite {
  id                  String              @id @default(cuid())
  companyId           String
  url                 String
  normalizedDomain    String
  title               String?
  snippet             String?
  source              CompanyWebsiteSource
  rank                Int?
  confidenceScore     Int
  isOfficialCandidate Boolean             @default(false)
  isSelected          Boolean             @default(false)
  reason              String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, confidenceScore])
  @@index([companyId, normalizedDomain])
}

model ImportLog {
  id            String          @id @default(cuid())
  batchId       String
  rowNumber     Int
  rawValue      String
  normalizedIco String?
  status        ImportLogStatus
  message       String?
  createdAt     DateTime        @default(now())

  batch SearchBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model ProcessingLog {
  id         String              @id @default(cuid())
  batchId    String
  companyId  String?
  step       String
  status     ProcessingLogStatus
  message    String
  detailJson Json?
  createdAt  DateTime            @default(now())

  batch   SearchBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  company Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([batchId, createdAt])
  @@index([companyId, createdAt])
}

model CompanyPerson {
  id               String           @id @default(cuid())
  companyId        String
  fullName         String
  firstName        String?
  lastName         String?
  position         String?
  department       String?
  sourceUrl        String
  sourcePageId     String
  contextText      String
  extractionMethod ExtractionMethod
  confidenceScore  Int
  reviewStatus     ReviewStatus     @default(unreviewed)
  isSelected       Boolean          @default(false)
  manuallyEdited   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  page     CrawledPage      @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)
  contacts CompanyContact[]
  contactScores ContactScore[]

  @@index([companyId, createdAt])
  @@index([companyId, fullName])
}

model CompanyContact {
  id               String           @id @default(cuid())
  companyId        String
  personId         String?
  contactType      ContactType
  value            String
  normalizedValue  String
  sourceUrl        String
  sourcePageId     String
  contextText      String
  extractionMethod ExtractionMethod
  confidenceScore  Int
  reviewStatus     ReviewStatus     @default(unreviewed)
  isSelected       Boolean          @default(false)
  manuallyEdited   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person  CompanyPerson? @relation(fields: [personId], references: [id], onDelete: SetNull)
  page    CrawledPage   @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)
  contactScores ContactScore[]

  @@index([companyId, normalizedValue])
  @@index([companyId, personId])
}

model ContactScore {
  id         String               @id @default(cuid())
  companyId  String
  personId   String?
  contactId  String?
  targetRole String
  score      Int
  category   ContactScoreCategory
  reasonsJson Json
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person  CompanyPerson? @relation(fields: [personId], references: [id], onDelete: SetNull)
  contact CompanyContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([companyId, score])
  @@index([companyId, category])
  @@index([personId])
  @@index([contactId])
}
