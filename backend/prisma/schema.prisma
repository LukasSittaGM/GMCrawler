generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SearchBatchStatus {
  draft
  ready
  processing
  done
  error
}

enum CompanyStatus {
  pending
  loading_ares
  finding_web
  crawling
  extracting
  done
  no_results
  error
}

enum ImportLogStatus {
  imported
  skipped
  invalid
  duplicate
}

enum ProcessingLogStatus {
  info
  success
  warning
  error
}

enum CompanyWebsiteSource {
  search
  ares
  manual
  imported
  other
}

model SearchBatch {
  id             String            @id @default(cuid())
  name           String
  note           String?
  targetRole     String?
  status         SearchBatchStatus @default(draft)
  totalCount     Int               @default(0)
  processedCount Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  companies      Company[]
  importLogs     ImportLog[]
  processingLogs ProcessingLog[]
}

model Company {
  id                    String        @id @default(cuid())
  batchId               String
  ico                   String
  companyName           String?
  legalForm             String?
  addressText           String?
  city                  String?
  postalCode            String?
  country               String?
  registrationStatus    String?
  createdDate           DateTime?
  dataBoxId             String?
  aresRawJson           Json?
  aresLoadedAt          DateTime?
  statutoryPersonsJson  Json?
  websiteUrl            String?
  websiteDomain         String?
  websiteConfidenceScore Int?
  websiteFoundAt        DateTime?
  status                CompanyStatus @default(pending)
  errorMessage          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  batch           SearchBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  processingLogs  ProcessingLog[]
  websites        CompanyWebsite[]

  @@unique([batchId, ico])
  @@index([batchId])
}

model CompanyWebsite {
  id                  String              @id @default(cuid())
  companyId           String
  url                 String
  normalizedDomain    String
  title               String?
  snippet             String?
  source              CompanyWebsiteSource
  rank                Int?
  confidenceScore     Int
  isOfficialCandidate Boolean             @default(false)
  isSelected          Boolean             @default(false)
  reason              String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, confidenceScore])
  @@index([companyId, normalizedDomain])
}

model ImportLog {
  id            String          @id @default(cuid())
  batchId       String
  rowNumber     Int
  rawValue      String
  normalizedIco String?
  status        ImportLogStatus
  message       String?
  createdAt     DateTime        @default(now())

  batch SearchBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model ProcessingLog {
  id         String              @id @default(cuid())
  batchId    String
  companyId  String?
  step       String
  status     ProcessingLogStatus
  message    String
  detailJson Json?
  createdAt  DateTime            @default(now())

  batch   SearchBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  company Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([batchId, createdAt])
  @@index([companyId, createdAt])
}
